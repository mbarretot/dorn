{
  "$schema": "http://json.schemastore.org/template",
  "author": "Dorn Contributors",
  "classifications": ["Web", "WebAPI", "Clean Architecture"],
  "identity": "Dorn.Templates.WebApi",
  "name": "Dorn Clean Architecture Web API",
  "description": "Production-ready Clean Architecture Web API with CQRS, layered structure, and Docker support.",
  "shortName": "dorn-webapi",
  "sourceName": "CleanArchWebApi",
  "preferNameDirectory": true,
  "symbols": {
    "IncludeTests": {
      "type": "parameter",
      "datatype": "bool",
      "defaultValue": "true",
      "description": "Include the xUnit test project for the Application layer."
    },
    "DatabaseProvider": {
      "type": "parameter",
      "datatype": "choice",
      "choices": [
        { "choice": "sqlite", "description": "SQLite — no external setup required (default)." },
        { "choice": "sqlserver", "description": "SQL Server, run via an Aspire-managed container." }
      ],
      "defaultValue": "sqlite",
      "description": "The EF Core database provider used for persistence."
    },
    "UseSqlServer": { "type": "computed", "value": "(DatabaseProvider == \"sqlserver\")" },
    "Orchestrator": {
      "type": "parameter",
      "datatype": "choice",
      "choices": [
        {
          "choice": "aspire",
          "description": "Local orchestration via .NET Aspire AppHost (default)."
        },
        {
          "choice": "docker-compose",
          "description": "Docker Compose scaffolding; no Aspire dependency."
        }
      ],
      "defaultValue": "aspire",
      "description": "Local orchestration approach for the generated service."
    },
    "UseAspire": { "type": "computed", "value": "(Orchestrator == \"aspire\")" }
  },
  "sources": [
    {
      "modifiers": [
        {
          "condition": "(!IncludeTests)",
          "exclude": ["tests/**"]
        },
        {
          "condition": "(UseSqlServer)",
          "rename": {
            "src/CleanArchWebApi.Infrastructure/Persistence/Migrations/SqlServer/": "src/CleanArchWebApi.Infrastructure/Persistence/Migrations/"
          },
          "exclude": ["src/CleanArchWebApi.Infrastructure/Persistence/Migrations/Sqlite/**"]
        },
        {
          "condition": "(!UseSqlServer)",
          "rename": {
            "src/CleanArchWebApi.Infrastructure/Persistence/Migrations/Sqlite/": "src/CleanArchWebApi.Infrastructure/Persistence/Migrations/"
          },
          "exclude": ["src/CleanArchWebApi.Infrastructure/Persistence/Migrations/SqlServer/**"]
        },
        {
          "condition": "(!UseAspire)",
          "exclude": [
            "src/CleanArchWebApi.AppHost/**",
            "src/CleanArchWebApi.ServiceDefaults/**"
          ]
        },
        {
          "condition": "(UseAspire)",
          "exclude": [
            "CleanArchWebApi.Compose.slnx",
            "docker-compose.yml",
            "docker-compose.SqlServer.yml"
          ]
        },
        {
          "condition": "(!UseAspire)",
          "rename": {
            "CleanArchWebApi.Compose.slnx": "CleanArchWebApi.slnx"
          },
          "exclude": ["CleanArchWebApi.slnx"]
        },
        {
          "condition": "(!UseAspire && UseSqlServer)",
          "rename": {
            "docker-compose.SqlServer.yml": "docker-compose.yml"
          },
          "exclude": ["docker-compose.yml"]
        },
        {
          "condition": "(!UseAspire && !UseSqlServer)",
          "exclude": ["docker-compose.SqlServer.yml"]
        }
      ]
    }
  ],
  "postActions": [
    {
      "description": "Restore NuGet packages required by this project.",
      "manualInstructions": [
        {
          "text": "Run 'dotnet restore'"
        }
      ],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    }
  ],
  "tags": {
    "language": "C#",
    "type": "project"
  }
}
