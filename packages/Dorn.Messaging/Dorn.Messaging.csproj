<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <PackageId>Dorn.Messaging</PackageId>
        <Description>In-process mediator implementation for Dorn.Messaging.Contracts -- dispatches commands/queries to a single handler and notifications to every registered handler, with pipeline behavior support. MIT-licensed, dependency-free alternative to MediatR.</Description>
        <PackageTags>dorn;mediator;cqrs</PackageTags>
    </PropertyGroup>
    <ItemGroup>
        <ProjectReference Include="..\Dorn.Messaging.Contracts\Dorn.Messaging.Contracts.csproj" />
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    </ItemGroup>
</Project>
